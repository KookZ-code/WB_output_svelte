# frontend/.env.example
# คัดลอกเป็น .env แล้วแก้ค่าตาม environment ที่ deploy
# ห้าม commit .env ขึ้น git
#
# ⚠️ ไฟล์นี้ใช้ตอน BUILD (Node.js process)
#    ไม่ใช่ runtime env ของ browser — ค่าทั้งหมดจะถูก bake เข้า bundle ตอน build

# ─────────────────────────────────────────────────────────────────
# ORIGIN — public URL ที่ user เปิดในเบราว์เซอร์ (ห้ามมี trailing /)
# ใช้สำหรับ CSRF token, cookie domain และ Set-Cookie headers
# ─────────────────────────────────────────────────────────────────
# Dev:        ไม่ต้องตั้ง (Vite dev server จัดการให้)
# Prod root:  https://app.example.com
# Prod sub:   https://app.example.com   (ไม่รวม sub-path — sub-path ใส่ใน BASE_PATH)
ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# BASE_PATH — sub-path ที่ IIS host ภายใต้ parent site (optional)
# ขึ้นต้นด้วย "/" และห้ามลงท้ายด้วย "/"
# ─────────────────────────────────────────────────────────────────
# Root site:        ปล่อยว่าง หรือไม่ตั้ง          (เปิดได้ที่ https://app.example.com/)
# Sub-path /myapp:  /myapp                          (เปิดได้ที่ https://app.example.com/myapp/)
# Sub-path /admin:  /admin
BASE_PATH=

# ─────────────────────────────────────────────────────────────────
# NODE_ENV — bundler/runtime mode
# ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────
# PORT — Node SSR process listening port (ตอน adapter-node รัน)
# ค่า default ของ adapter-node = 3000
# IIS + iisnode จะ override เองอัตโนมัติด้วย named pipe — ปล่อยตามนี้ได้
# ─────────────────────────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────────
# API center (Dashboad_API_rush) — middleware between frontend and DB.
# Hourly-UPH data (central.db) is now served by the Rust API; the frontend
# no longer reads SQLite directly. Server-only — do NOT use a VITE_ prefix.
# ─────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8080
API_KEY=mch_dev_12345
API_TIMEOUT=10000

# WIP source (assembly A01 API) — WireBond-stage WIP per package (POST, no body)
WIP_API_URL=http://mth-vm-asoprd/assyapi/api/A01/pkgDOI

# ─────────────────────────────────────────────────────────────────
# Excel plan — still read locally by the frontend (plan targets / vs-target %).
# ใช้ forward slash ได้บน Windows (Node ทำได้)
# ─────────────────────────────────────────────────────────────────
XLSX_PATH=./data/wb_plan.xlsx

# หมายเหตุ: utilization + events overlay (ตาราง by-machine) ดึงจาก API center
# (/api/v1/wb/report) ผ่าน API_BASE_URL ด้านบนแล้ว — ไม่ใช้ WB_REPORT_URL :8001 อีกต่อไป
